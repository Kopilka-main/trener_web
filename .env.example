# Окружение API
NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/trener

# Секрет cookie-сессий (минимум 32 символа)
COOKIE_SECRET=change-me-to-a-long-random-string-min-32

# Каталог загрузок (локальный диск/volume)
UPLOADS_DIR=./data/uploads

# Web Push (VAPID). Сгенерировать: npx web-push generate-vapid-keys
# Без ключей системные push-уведомления просто отключены.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@fitbond.ru

# SMTP (email-провайдер) — используется для писем сброса пароля (6-значный код).
# Провайдер: Resend по SMTP. Без SMTP_HOST письма не шлются (dev-заглушка в лог).
# SMTP_PORT=465 → implicit TLS (secure); 587 → STARTTLS. Секреты НЕ коммитить.
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_USER=resend
#   SMTP_PASSWORD=<resend api key>
#   SMTP_FROM="FitBond <noreply@ВАШ_ДОМЕН>"
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# OAuth-вход (VK ID / Яндекс). Без client id/secret провайдер мягко недоступен (503).
# OAUTH_REDIRECT_BASE — публичный базовый адрес API для redirect_uri коллбэка (без слэша).
# redirect_uri = <OAUTH_REDIRECT_BASE>/api/auth/oauth/<provider>/callback
VK_CLIENT_ID=
VK_CLIENT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=https://app.fitbond.ru
