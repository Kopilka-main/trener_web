# Caddy: TLS-терминация + маршрутизация по поддоменам.
# Сертификаты Let's Encrypt выпускаются и продлеваются автоматически
# (нужны открытые порты 80/443 и делегированный домен fitbond.ru).
#
# email — для уведомлений Let's Encrypt об истечении; задаётся через ACME_EMAIL.

{
	email {$ACME_EMAIL}
}

# Приложение тренера.
app.fitbond.ru {
	reverse_proxy nginx:80
}

# Приложение клиента.
my.fitbond.ru {
	reverse_proxy web-client:80
}

# Мессенджер (отдельный compose-стек; web опубликован на хосте :8090).
# web-контейнер мессенджера сам проксирует /api на свой api внутри своей сети.
chat.fitbond.ru {
	reverse_proxy host.docker.internal:8090
}
