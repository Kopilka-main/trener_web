# Зависимости
node_modules/

# Сборки
dist/
build/
*.tsbuildinfo

# Окружение и секреты
.env
.env.*
!.env.example

# Локальный docker-оверрайд (публикует порт API для dev-Vite) — не в git/прод
docker-compose.override.yml

# Данные и аплоады
data/
*.db
*.sqlite

# Дампы БД (локальные бэкапы перед миграцией)
*.dump

# Медиа каталога упражнений (бинарь ~200 МБ, кладётся локально/в volume, не в git)
apps/api/media/

# Логи
*.log
npm-debug.log*

# Системные
.DS_Store
Thumbs.db

# Секреты (service-account FCM и пр.) — не коммитим
secrets/
*-firebase-adminsdk-*.json
