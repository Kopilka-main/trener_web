{
  "name": "@trener/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:prod": "node dist/migrate.js",
    "seed:catalog": "node dist/seed-catalog.js",
    "seed:catalog-300": "tsx src/seed-catalog-300.ts",
    "seed:catalog-300:prod": "node -e \"const fs=require('fs');fs.mkdirSync('dist/data',{recursive:true});fs.copyFileSync('src/data/catalog-300.json','dist/data/catalog-300.json')\" && node dist/seed-catalog-300.js",
    "seed:templates": "tsx src/seed-templates.ts",
    "seed:templates:prod": "node dist/seed-templates.js",
    "seed:thumbs": "node scripts/crop-thumbs.mjs",
    "seed:thumbs:small": "node scripts/use-small-thumbs.mjs"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@trener/shared": "*",
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "firebase-admin": "^14.0.0",
    "nodemailer": "^6.9.16",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "^0.30.0",
    "sharp": "^0.34.5",
    "tsx": "^4.19.2"
  }
}
